# ─── Supabase Configuration ───────────────────────────────────────────────────
# Public environment variables (safe for browser exposure)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Movie Data APIs ──────────────────────────────────────────────────────────
# Secret server-side API keys (do not expose to browser)
OMDB_API_KEY=your_omdb_api_key_here
TMDB_API_KEY=your_tmdb_api_key_here

# Public TMDB API Key (Optional client fallback)
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here

# ─── YouTube Data API ─────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── FastAPI Machine Learning Microservice ───────────────────────────────────
# Production ML backend endpoint (e.g. Render, Railway, Fly.io, or Hugging Face)
NEXT_PUBLIC_ML_API_URL=https://cinecurator-ml-api.onrender.com
ML_API_URL=https://cinecurator-ml-api.onrender.com
